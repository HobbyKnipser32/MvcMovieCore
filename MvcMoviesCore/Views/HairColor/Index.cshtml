@{
    ViewData["Title"] = "Haarfarben";
}
<div class="container-fluid">
    <p>
        <a asp-action="Create" title="Haarfarbe hinzufügen">
            <i class="fa-regular fa-square-plus fa-beat fa-2xl" style="color: #63E6BE; --fa-animation-duration: 2s;"></i>
        </a>
    </p>
    <table id="hairColorIndex" class="table table-striped cell-border table-hover compact" cellspacing="0" style="width: 100%; word-wrap:break-word; table-layout: auto;">
        <thead>
            <tr>
                <th>Haarfarbe</th>
                <th>Beschreibung</th>
                <th>Anzahl</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
    </table>
    <div class="col-md-6" style="margin: 0 auto;" >
        <div>
            <canvas id="diagram"></canvas>
        </div>
    </div>
    <div class="loader"></div>
</div>

@section Scripts
{
    <partial name="_DataTableScripts" />

    <script>
        $(document).ready(function () {
            $('#hairColorIndex').DataTable({
                ajax: {
                    url: appRootPath + '/api/HairColorApi',
                    dataSrc: '',
                    beforeSend: function(){ $('.loader').show() },
                    complete: function(){ $('.loader').hide() }
                },
                columns: [
                    { data: 'Color' },
                    { data: 'Description' },
                    { data: 'Count' },
                    {
                        data: 'Id',
                        render: function (data, type, full, meta) {
                            if (data && type === 'display') {
                                var url = '@Url.Action("Edit", "HairColor")' + '/' + data;
                                return '<a href="' + url + '" title="Haarfarbe bearbeiten">' +
                                    '<i class="fa-solid fa-pen fa-bounce" style="color: #74C0FC; --fa-animation-duration: 2s;"></i>';
                            }
                            return '';
                        }
                    },
                    {
                        data: 'Id',
                        render: function (data, type, full, meta) {
                            if (data && type === 'display') {
                                var id = "'" + data + "'";
                                return '<button name="id" style="background-color: transparent; color: red; border: hidden"' +
                                    'onClick="deleteLink(' + id + ')" title="Haarfarbe löschen">' +
                                    '<i class="fa-regular fa-trash-can fa-fade" style="color: #ff0000; --fa-animation-duration: 2s;"></i>';
                            }
                            return '';
                        }
                    },
                ],
                ordering: true,
                fixedHeader: {
                    header: true,
                },
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                iDisplayLength: 25,
            });

            $.ajax({
                url: appRootPath + '/api/HairColorApi/GetDiagramData',
                type: 'get',
                data: '',
                beforeSend: function(){ $('.loader').show() },
                success: onSuccess,
                fail: function (response) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: 'Fehler beim laden der Daten.',
                        footer: response.responseText
                    })
                },
                complete: function(){ $('.loader').hide() }
            });
        })

        function deleteLink(id) {
            Swal.fire({
                text: 'Haarfarbe löschen?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Ja',
                cancelButtonText: 'Nein'
            }).then(function (result) {
                if (result.value) {
                    var url = appRootPath + '/api/HairColorApi/' + id;
                    $.ajax({
                        url: url,
                        type: 'POST',
                        async: false,
                        statusCode: {
                            404: function () {
                                alert("function not found");
                            }
                        },
                        success: function () {
                            $('#hairColorIndex').DataTable().ajax.reload();
                            Swal.fire({
                                icon: 'success',
                                text: 'Haarfarbe erfolgreich gelöscht.',
                                showConfirmButton: false,
                                timer: 2000
                            })
                        },
                        error: function (response) {
                            Swal.fire({
                                icon: 'error',
                                title: 'Oops...',
                                text: 'Haarfarbe konnte nicht gelöscht werden!',
                                footer: response.responseText
                            })
                        }
                    })
                };
            });
        };

        function onSuccess(data){
            let datas = JSON.parse(data)
            let chart = $('#diagram');
            let dataChart = {
                labels: datas.Labels,
                backgroundColor: datas.BackgroundColor,
                datasets:[]
            }
            for (let i = 0; i < datas.DataSets.length; i++){
                let dataset = { label: datas.DataSets[i].Label, data: datas.DataSets[i].Data, type: datas.DataSets[i].Type, backgroundColor: datas.DataSets[i].BackgroundColor };
                dataChart.datasets.push(dataset);
            }

            new Chart(chart, {
                data: {
                    datasets:dataChart.datasets,
                    labels: dataChart.labels,
                    backgroundColor: dataChart.backgroundColor
                },
                // options: {
                //     scales: {
                //         y: {
                //             beginAtZero: true,
                //             type: 'logarithmic',
                //         }
                //     }
                // }
            });
        }
    </script>
}